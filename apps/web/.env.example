# ── apps/web/.env.example ────────────────────────────────────────────
# Template only. For local development, copy this file to
# apps/web/.env.development.local so Vite cannot accidentally reuse production
# values. These are PUBLIC client values. NEVER put ANTHROPIC_API_KEY or a
# service_role/secret key here.

VITE_SUPABASE_ENV=development
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
