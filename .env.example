# ── Root .env.example ────────────────────────────────────────────────
# Copy to .env only if you need root-level tooling. Frontend vars live in
# apps/web/.env (see apps/web/.env.example). Never commit real .env files.

# Server-side ONLY — used by the Supabase Edge Function (supabase/functions/ingest).
# Set it as a Supabase secret, NEVER expose it to the browser / VITE_ vars:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=

# Supabase project ref used by CLI commands (optional, for local convenience)
SUPABASE_PROJECT_ID=
